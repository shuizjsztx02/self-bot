# ==================== 生产环境配置示例 ====================
# 复制此文件为 .env 并修改配置

# Environment
ENV=production

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database (容器内路径)
DATABASE_URL=sqlite+aiosqlite:///./data/database/selfbot.db

# ==================== LLM Provider 配置 ====================
# 根据实际使用的 LLM 提供商配置

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# DeepSeek (推荐国内使用)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Qwen (通义千问)
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# GLM (智谱)
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-plus

# 默认 LLM 提供商: openai, deepseek, qwen, glm, ollama
DEFAULT_LLM_PROVIDER=deepseek

# ==================== Search APIs (可选) ====================
TAVILY_API_KEY=your-tavily-api-key
SERPAPI_API_KEY=your-serpapi-api-key

# ==================== MCP Settings ====================
MCP_SERVER_NAME=self-bot
MCP_SERVER_VERSION=1.0.0

# ==================== 路径配置 (容器内路径，一般无需修改) ====================
WORKSPACE_PATH=/app/workspace
KB_DOCUMENT_PATH=/app/data/knowledge_base/documents
KB_VECTOR_PATH=/app/data/knowledge_base/vectors
KB_INDEX_PATH=/app/data/knowledge_base/indexes
AGENT_MEMORY_PATH=/app/data/agent/memories
AGENT_VECTOR_PATH=/app/data/agent/vectors
AGENT_TRACE_PATH=/app/data/agent/traces
MODEL_HUB_PATH=/app/model_hub

# ==================== Embedding 模型配置 ====================
EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

# 如果服务器没有 GPU，使用 CPU
MODEL_DEVICE=cpu
MODEL_FORCE_CPU=true

# ==================== Agent 配置 ====================
AGENT_MAX_ITERATIONS=150
RESEARCHER_MAX_ITERATIONS=80

# ==================== HTTP 客户端配置 ====================
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=40
HTTP_READ_TIMEOUT=60.0
HTTP_MAX_RETRIES=3
